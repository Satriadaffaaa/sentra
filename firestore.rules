rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    // Pastikan request berasal dari pengguna yang sudah login
    function isAuthenticated() {
      return request.auth != null;
    }

    // Pastikan user hanya mengakses data miliknya sendiri
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Shorthand: sudah login DAN pemilik data
    function isAuthOwner(userId) {
      return isAuthenticated() && isOwner(userId);
    }

    // Cek apakah field yang masuk adalah subset dari field yang diizinkan
    function hasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Pastikan field wajib ada
    function hasAll(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // =========================================================
    // BLOK UTAMA: Semua akses di bawah /users/{userId}/
    // =========================================================
    match /users/{userId} {

      // Dokumen profil user (opsional, jika ingin menyimpan displayName dll.)
      allow read, write: if isAuthOwner(userId);

      // -------------------------------------------------------
      // ACCOUNTS — Rekening bank, e-wallet, kas, kartu kredit
      // -------------------------------------------------------
      match /accounts/{accountId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'balance', 'currency', 'type', 'icon', 'color'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && (request.resource.data.balance is number || request.resource.data.balance is string)
                      && request.resource.data.currency is string
                      && request.resource.data.type in ['bank', 'cash', 'e_wallet', 'credit_card', 'investment']
                      && request.resource.data.icon is string
                      && request.resource.data.color is string;
        allow update: if isAuthOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && (request.resource.data.balance is number || request.resource.data.balance is string)
                      && request.resource.data.currency is string
                      && request.resource.data.type in ['bank', 'cash', 'e_wallet', 'credit_card', 'investment'];
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // TRANSACTIONS — Pemasukan, pengeluaran, transfer
      // -------------------------------------------------------
      match /transactions/{transactionId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['amount', 'type', 'categoryId', 'description', 'date', 'accountId'])
                      && (request.resource.data.amount is number || request.resource.data.amount is string)
                      && request.resource.data.type in ['income', 'expense', 'transfer']
                      && request.resource.data.categoryId is string
                      && request.resource.data.description is string
                      && request.resource.data.date is string
                      && request.resource.data.accountId is string;
        allow update: if isAuthOwner(userId)
                      && (request.resource.data.amount is number || request.resource.data.amount is string)
                      && request.resource.data.type in ['income', 'expense', 'transfer'];
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // CATEGORIES — Kategori kustom per pengguna
      // -------------------------------------------------------
      match /categories/{categoryId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'icon', 'color', 'type'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.icon is string
                      && request.resource.data.color is string
                      && request.resource.data.type in ['income', 'expense'];
        allow update: if isAuthOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.type in ['income', 'expense'];
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // BUDGETS — Batas anggaran per kategori
      // -------------------------------------------------------
      match /budgets/{budgetId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['categoryId', 'amountLimit'])
                      && request.resource.data.categoryId is string
                      && (request.resource.data.amountLimit is number || request.resource.data.amountLimit is string);
        allow update: if isAuthOwner(userId)
                      && request.resource.data.categoryId is string
                      && (request.resource.data.amountLimit is number || request.resource.data.amountLimit is string);
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // SAVINGS GOALS — Target tabungan
      // -------------------------------------------------------
      match /savingsGoals/{goalId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'targetAmount', 'currentAmount', 'targetDate'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && (request.resource.data.targetAmount is number || request.resource.data.targetAmount is string)
                      && (request.resource.data.currentAmount is number || request.resource.data.currentAmount is string)
                      && request.resource.data.targetDate is string;
        allow update: if isAuthOwner(userId)
                      && request.resource.data.name is string
                      && (request.resource.data.targetAmount is number || request.resource.data.targetAmount is string)
                      && (request.resource.data.currentAmount is number || request.resource.data.currentAmount is string);
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // DEBTS — Utang & piutang
      // -------------------------------------------------------
      match /debts/{debtId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'type', 'totalAmount', 'paidAmount', 'dueDate', 'status'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.type in ['debt', 'loan']
                      && (request.resource.data.totalAmount is number || request.resource.data.totalAmount is string)
                      && (request.resource.data.paidAmount is number || request.resource.data.paidAmount is string)
                      && request.resource.data.dueDate is string
                      && request.resource.data.status in ['active', 'paid'];
        allow update: if isAuthOwner(userId)
                      && request.resource.data.type in ['debt', 'loan']
                      && (request.resource.data.totalAmount is number || request.resource.data.totalAmount is string)
                      && (request.resource.data.paidAmount is number || request.resource.data.paidAmount is string)
                      && request.resource.data.status in ['active', 'paid'];
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // SUBSCRIPTIONS — Langganan & tagihan berulang
      // -------------------------------------------------------
      match /subscriptions/{subscriptionId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'amount', 'type', 'accountId', 'categoryId', 'nextDueDate', 'active'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && (request.resource.data.amount is number || request.resource.data.amount is string)
                      && request.resource.data.type in ['auto', 'manual']
                      && request.resource.data.accountId is string
                      && request.resource.data.categoryId is string
                      && request.resource.data.nextDueDate is string
                      && request.resource.data.active is bool;
        allow update: if isAuthOwner(userId)
                      && request.resource.data.name is string
                      && (request.resource.data.amount is number || request.resource.data.amount is string)
                      && request.resource.data.type in ['auto', 'manual']
                      && request.resource.data.active is bool;
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // INVESTMENTS — Aset investasi (saham, kripto, emas, dll.)
      // -------------------------------------------------------
      match /investments/{investmentId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['name', 'type', 'currentPrice'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.type in [
                           'stock', 'mutual_fund', 'crypto', 'gold',
                           'bond', 'deposit', 'p2p', 'property', 'other'
                         ]
                      && (request.resource.data.currentPrice is number || request.resource.data.currentPrice is string);
        allow update: if isAuthOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.type in [
                           'stock', 'mutual_fund', 'crypto', 'gold',
                           'bond', 'deposit', 'p2p', 'property', 'other'
                         ]
                      && (request.resource.data.currentPrice is number || request.resource.data.currentPrice is string);
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // INVESTMENT TRANSACTIONS — Beli/jual/dividen/bunga
      // -------------------------------------------------------
      match /investmentTransactions/{invTxId} {
        allow read:   if isAuthOwner(userId);
        allow create: if isAuthOwner(userId)
                      && hasAll(['investmentId', 'type', 'amount', 'quantity', 'pricePerUnit', 'date'])
                      && request.resource.data.investmentId is string
                      && request.resource.data.type in ['buy', 'sell', 'dividend', 'interest']
                      && (request.resource.data.amount is number || request.resource.data.amount is string)
                      && (request.resource.data.quantity is number || request.resource.data.quantity is string)
                      && (request.resource.data.pricePerUnit is number || request.resource.data.pricePerUnit is string)
                      && request.resource.data.date is string;
        allow update: if isAuthOwner(userId)
                      && request.resource.data.type in ['buy', 'sell', 'dividend', 'interest']
                      && (request.resource.data.amount is number || request.resource.data.amount is string);
        allow delete: if isAuthOwner(userId);
      }

      // -------------------------------------------------------
      // CONFIG / SETTINGS — Pengaturan aplikasi (1 dokumen per user)
      // -------------------------------------------------------
      match /config/{document} {
        allow read:   if isAuthOwner(userId);
        allow write:  if isAuthOwner(userId)
                      && document == 'settings'
                      && hasAll(['baseCurrency', 'exchangeRates'])
                      && request.resource.data.baseCurrency is string
                      && request.resource.data.exchangeRates is map
                      && (!('passcodeEnabled' in request.resource.data) || request.resource.data.passcodeEnabled is bool)
                      && (!('passcodePIN' in request.resource.data) || (request.resource.data.passcodePIN is string && (request.resource.data.passcodePIN.size() == 0 || request.resource.data.passcodePIN.size() == 4)));
      }

    } // end match /users/{userId}

    // =========================================================
    // DENY ALL — Tolak semua akses lain yang tidak terdefinisi
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
